```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Build artifacts
dist/
build/
target/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Testing
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# Runtime
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System
*.tmp
*.temp
*~
.DS_Store
ehthumbs.db
Icon?
Thumbs.db
```